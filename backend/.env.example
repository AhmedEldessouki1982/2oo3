NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
APP_NAME=2oo3

# Local Docker Postgres. Values are development placeholders only.
POSTGRES_DB=2oo3
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/2oo3?schema=public

# Generate real secrets per environment. Never commit local .env files.
JWT_SECRET=replace-with-a-long-random-secret
PROVIDER_KEY_ENCRYPTION_SECRET=replace-with-32-byte-base64-secret
