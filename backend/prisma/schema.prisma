generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  COMMISSIONING_ENGINEER
  LEAD_ENGINEER
  VIEWER
}

enum Provider {
  OPENAI
  ANTHROPIC
  GOOGLE
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  COMPACTING
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ProviderResponseStatus {
  PENDING
  STREAMING
  COMPLETED
  FAILED
}

enum ComparisonStatus {
  PENDING
  COMPLETED
  FAILED
}

enum AttachmentExtractionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  displayName         String               @map("display_name")
  role                UserRole             @default(COMMISSIONING_ENGINEER)
  passwordHash        String?              @map("password_hash")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  attachments         Attachment[]
  conversations       Conversation[]
  messages            Message[]
  providerCredentials ProviderCredential[]

  @@map("users")
}

model ProviderCredential {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  provider             Provider
  encryptedKeyMaterial String   @map("encrypted_key_material") @db.Text
  keyFingerprint       String?  @map("key_fingerprint")
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("provider_credentials")
}

model Conversation {
  id                String             @id @default(cuid())
  userId            String             @map("user_id")
  title             String
  status            ConversationStatus @default(ACTIVE)
  contextSummary    String?            @map("context_summary") @db.Text
  compressionState  Json?              @map("compression_state")
  lastCompressedAt  DateTime?          @map("last_compressed_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  attachments       Attachment[]
  comparisonResults ComparisonResult[]
  messages          Message[]
  providerResponses ProviderResponse[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([status])
  @@map("conversations")
}

model Message {
  id                 String             @id @default(cuid())
  conversationId     String             @map("conversation_id")
  userId             String             @map("user_id")
  role               MessageRole
  content            String             @db.Text
  metadata           Json?
  compressed         Boolean            @default(false)
  contextFingerprint String?            @map("context_fingerprint")
  createdAt          DateTime           @default(now()) @map("created_at")
  attachments        Attachment[]
  comparisonResult   ComparisonResult?
  conversation       Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  providerResponses  ProviderResponse[]
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId])
  @@map("messages")
}

model ProviderResponse {
  id             String                 @id @default(cuid())
  conversationId String                 @map("conversation_id")
  messageId      String                 @map("message_id")
  provider       Provider
  status         ProviderResponseStatus @default(PENDING)
  content        String?                @db.Text
  latencyMs      Int?                   @map("latency_ms")
  errorCode      String?                @map("error_code")
  errorSummary   String?                @map("error_summary") @db.Text
  metadata       Json?
  startedAt      DateTime?              @map("started_at")
  completedAt    DateTime?              @map("completed_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  conversation   Conversation           @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message                @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, provider])
  @@index([conversationId, provider])
  @@map("provider_responses")
}

model ComparisonResult {
  id                 String           @id @default(cuid())
  conversationId     String           @map("conversation_id")
  messageId          String           @unique @map("message_id")
  status             ComparisonStatus @default(PENDING)
  agreements         Json
  disagreements      Json
  uniqueInsights     Json             @map("unique_insights")
  risks              Json
  nextInvestigations Json             @map("next_investigations")
  errorSummary       String?          @map("error_summary") @db.Text
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  conversation       Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message            Message          @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("comparison_results")
}

model Attachment {
  id               String                     @id @default(cuid())
  userId           String                     @map("user_id")
  conversationId   String?                    @map("conversation_id")
  messageId        String?                    @map("message_id")
  filename         String
  mimeType         String                     @map("mime_type")
  sizeBytes        Int?                       @map("size_bytes")
  storageUri       String?                    @map("storage_uri")
  extractionStatus AttachmentExtractionStatus @default(PENDING) @map("extraction_status")
  extractedText    String?                    @map("extracted_text") @db.Text
  distilledContext String?                    @map("distilled_context") @db.Text
  metadata         Json?
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")
  conversation     Conversation?              @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message          Message?                   @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([messageId])
  @@index([userId])
  @@map("attachments")
}
