# Root development environment template for 2oo3.
# Copy values into local .env files as needed. Never commit real secrets.

NODE_ENV=development

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000/api

# Backend
PORT=3000
FRONTEND_URL=http://localhost:5173
APP_NAME=2oo3

# Database placeholder for Milestone 2
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/2oo3

# Auth placeholders for Milestone 3
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Provider credential encryption placeholder for Milestone 8
PROVIDER_KEY_ENCRYPTION_SECRET=replace-with-32-byte-base64-secret

# Optional local provider keys for manual development only.
# User-supplied provider keys will be stored encrypted by the app, not here.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Attachment pipeline placeholders for Milestone 7
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=2oo3-dev-attachments
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
